---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const posts = await getCollection('blog');
const recentPosts = posts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()).slice(0, 3);
---

<Layout title="S.Zhang Laboratory" isHome={true}>
  <!-- 1. Hero Section -->
  <section class="hero">
    <div class="slideshow">
      <div class="slide active" style={`background-image: url('${base}uploads/2018/12/cropped-Candy-dots.png')`}></div>
      <div class="slide" style={`background-image: url('${base}uploads/2018/12/cropped-Brain_astrocyte_microglia_10x-lens.jpg')`}></div>
      <div class="slide" style={`background-image: url('${base}uploads/2018/12/cropped-BBB.jpg')`}></div>
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content container">
      <img src={`${base}uploads/2018/12/Evolving-Minds-2.png`} alt="Evolving Minds" class="hero-logo reveal active" />
      <h1 class="reveal active stagger-1 hero-title">
        <span class="title-top">Deciphering the</span>
        <span class="title-bottom serif-text">Architecture of Life</span>
      </h1>
      <p class="reveal active stagger-2 hero-description">Exploring the Beauty of Biology at the UT Southwestern Medical Center.</p>
      <div class="hero-btns reveal active stagger-3">
        <a href={`${base}research/`} class="btn-primary">Our Research</a>
        <a href={`${base}team/`} class="btn-outline hero-btn-alt">Meet the Team</a>
      </div>
    </div>
  </section>

  <!-- 2. Philosophy Section -->
  <section class="mission reveal">
    <div class="container small-container">
      <h2 class="section-label">Our Philosophy</h2>
      <p class="mission-text serif-text">
        Life is a form of art. Underneath disease, there is a logic: molecular, precise, and hidden. 
        We work where <span class="highlight">single-cell genetics</span> meets <span class="highlight">high-definition imaging</span>, 
        learning to read what was always there but never fully seen.
      </p>
    </div>
  </section>

  <!-- 3. Research Pillars -->
  <section class="pillars">
    <div class="container">
      <div class="pillar-grid">
        <a href={`${base}research/#theme-1`} class="pillar-card reveal stagger-1">
          <div class="pillar-count">01</div>
          <h3>Tumor Evolution</h3>
          <p>Defining and tracking evolving tumor heterogeneity using single-cell analysis and systems biology.</p>
          <span class="pillar-cta">Learn More →</span>
        </a>
        <a href={`${base}research/#theme-2`} class="pillar-card reveal stagger-2">
          <div class="pillar-count">02</div>
          <h3>Metastasis</h3>
          <p>Investigating how tumor cells colonize and adapt to unique, complex microenvironments.</p>
          <span class="pillar-cta">Learn More →</span>
        </a>
        <a href={`${base}research/#theme-3`} class="pillar-card reveal stagger-3">
          <div class="pillar-count">03</div>
          <h3>Genetic Networks</h3>
          <p>Mapping epistatic networks and combinatorial genetic interactions that shape metastatic fitness and niche adaptation.</p>
          <span class="pillar-cta">Learn More →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 4. Latest News Highlight -->
  <section class="journal">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">The Lab Journal</h2>
        <a href={`${base}blog/`} class="view-all-link">View all entries →</a>
      </div>
      
      <div class="post-grid">
        {recentPosts.map(post => (
          <article class="post-item reveal">
            <time class="post-date">{new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
            <h3 class="post-item-title"><a href={`${base}blog/${post.slug}/`}>{post.data.title}</a></h3>
            <p class="post-excerpt">{post.data.description || "Reading the patterns of life through discovery..."}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Social & Community Section -->
  <section class="social-updates">
    <div class="container reveal">
      <div class="social-grid">
        <div class="social-info">
          <h2 class="section-title serif-text">Live Updates</h2>
          <p class="social-description">Follow our daily investigations and community news directly from the bench.</p>
          <a href="https://bsky.app/profile/s-zhang-lab.bsky.social" target="_blank" class="btn-outline">Follow on Bluesky</a>
        </div>
        <div class="social-feed">
          <bsky-embed
            username="s-zhang-lab.bsky.social"
            limit="3"
            mode="light">
          </bsky-embed>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Script management for View Transitions
  function initHome() {
    // 1. Hero Slideshow
    let cur = 0;
    const slides = document.querySelectorAll('.slide');
    if (slides.length > 1) {
      const interval = setInterval(() => {
        slides[cur]?.classList.remove('active');
        cur = (cur + 1) % slides.length;
        slides[cur]?.classList.add('active');
      }, 6000);
      
      // 2. Cleanup on page navigation
      document.addEventListener('astro:before-preparation', () => clearInterval(interval), { once: true });
      }
      }

  // Initial load
  initHome();
  // Handle view transitions
  document.addEventListener('astro:page-load', initHome);
</script>

<style>
  /* Hero Styles */
  .hero {
    height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #000;
    color: white;
    overflow: hidden;
    text-align: center;
  }

  .slideshow, .slide { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
  .slide { 
    background-size: cover; background-position: center; opacity: 0; 
    transition: opacity 2.5s ease-in-out; 
  }
  .slide.active { opacity: 0.6; }

  .hero-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: radial-gradient(circle, transparent 20%, rgba(0,0,0,0.5) 100%);
    z-index: 1;
  }

  .hero-content { position: relative; z-index: 2; max-width: 900px; padding: 0 40px; }
  .hero-logo { max-height: 220px; width: auto; margin-bottom: 2.5rem; filter: brightness(0) invert(1); }
  
  .hero-title { 
    margin-bottom: 2rem; 
    line-height: 1.1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .title-top {
    font-size: 1rem;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    font-family: var(--font-ui);
    opacity: 0.8;
  }

  .title-bottom {
    font-size: 3rem;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .hero-description { 
    font-size: 1rem; 
    font-weight: 300;
    opacity: 0.9; 
    max-width: 700px; 
    margin: 0 auto 3.5rem auto; 
    font-family: var(--font-ui);
    letter-spacing: 0.05em;
    line-height: 1.6;
  }
  
  .hero-btn-alt { color: white !important; border-color: rgba(255,255,255,0.3) !important; }

  /* Philosophy */
  .small-container { max-width: 850px; text-align: center; }
  .section-label {
    text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.25em;
    color: var(--accent-muted); margin-bottom: 2.5rem; display: block;
  }
  .mission-text { font-size: 2.2rem; line-height: 1.4; color: var(--text-main); }
  .highlight { border-bottom: 1px solid var(--accent-muted); }

  /* Pillars - Interactive Cards */
  .pillar-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4rem; }
  
  .pillar-card {
    text-decoration: none;
    color: inherit;
    transition: transform 0.4s ease;
    display: block;
  }

  .pillar-card:hover { transform: translateY(-10px); }

  .pillar-count { font-size: 0.85rem; font-weight: 600; color: var(--accent-muted); margin-bottom: 1.5rem; display: block; }
  
  .pillar-card h3 { 
    font-size: 1.6rem; 
    margin-bottom: 1rem; 
    transition: color 0.3s;
  }

  .pillar-card:hover h3 { color: var(--accent-muted); }

  .pillar-card p { color: var(--text-muted); font-size: 1rem; margin-bottom: 1.5rem; }

  .pillar-cta {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    color: var(--accent-muted);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
  }

  .pillar-card:hover .pillar-cta {
    opacity: 1;
    transform: translateX(0);
  }

  /* Journal Highlight */
  .section-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 4rem; border-bottom: 1px solid var(--border-light); padding-bottom: 2rem;
  }
  .section-title { font-size: 2.8rem; }
  .view-all-link { font-size: 0.85rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; }

  .post-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem; }
  .post-date { font-size: 0.75rem; color: var(--accent-muted); text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 1.2rem; display: block; }
  .post-item-title { font-size: 1.4rem; margin-bottom: 1rem; line-height: 1.3; }
  .post-item-title a:hover { color: var(--accent-muted); }
  .post-excerpt { font-size: 0.95rem; color: var(--text-muted); line-height: 1.7; }

  /* Social Updates Section */
  .social-updates {
    background-color: var(--bg-alt);
    padding: 120px 0;
  }

  .social-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 80px;
    align-items: center;
  }

  .social-description {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin: 2rem 0 3rem 0;
    max-width: 400px;
    line-height: 1.6;
  }

  .social-feed {
    background: white;
    padding: 20px;
    border-radius: 4px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.03);
  }

  @media (max-width: 992px) {
    .hero h1 { font-size: 2.5rem; }
    .hero-logo { max-height: 140px; }
    .mission-text { font-size: 1.6rem; }
    .pillar-grid, .post-grid, .social-grid { grid-template-columns: 1fr; gap: 3rem; }
    .social-info { text-align: center; }
    .social-description { margin: 2rem auto 3rem auto; }
  }
</style>
