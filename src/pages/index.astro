---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const posts = await getCollection('blog');
const recentPosts = posts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()).slice(0, 5);
---

<Layout title="Home">
  <div class="site-main container">
    <div class="content-area">
      <div class="post-feed">
        {recentPosts.map(post => (
          <article class="post-card">
            <header class="entry-header">
              <h2 class="entry-title"><a href={`${base}blog/${post.slug}`}>{post.data.title}</a></h2>
              <div class="entry-meta">
                <span class="posted-on">
                  <a href={`${base}blog/${post.slug}`}>
                    <time>{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                  </a>
                </span>
                <span class="byline">Admin</span>
              </div>
            </header>
            
            <div class="entry-summary">
              {post.data.description ? (
                <p>{post.data.description}</p>
              ) : (
                <p>Keep reading to discover more about this topic...</p>
              )}
            </div>
            
            <div class="more-link-wrapper">
              <a href={`${base}blog/${post.slug}`} class="button more-link">Read more</a>
            </div>
          </article>
        ))}
      </div>
      
      <div class="pagination">
        <a href={`${base}blog`} class="button">Older posts</a>
      </div>
    </div>
    
    <aside class="sidebar">
      <div class="widget">
        <h2 class="widget-title">Bluesky Feed</h2>
        
        <!-- Bluesky Embed Component -->
        <bsky-embed
          username="s-zhang-lab.bsky.social"
          limit="3"
          mode="light">
        </bsky-embed>
        
        <!-- Required Script for the bsky-embed component -->
        <script type="module" src="https://cdn.jsdelivr.net/npm/bsky-embed/dist/bsky-embed.es.js" async></script>
        
        <p class="twitter-follow" style="margin-top: 15px;">
          <a href="https://bsky.app/profile/s-zhang-lab.bsky.social" target="_blank" rel="noopener noreferrer">Follow @s-zhang-lab on Bluesky →</a>
        </p>
      </div>
    </aside>
  </div>
</Layout>

<style>
  .site-main {
    max-width: 1140px;
    margin: 4rem auto;
    display: flex;
    gap: 4rem;
  }
  
  .content-area {
    flex: 1;
    max-width: 800px;
  }
  
  .sidebar {
    width: 300px;
    flex-shrink: 0;
  }
  
  .widget {
    margin-bottom: 2rem;
  }
  
  .widget-title {
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border-color);
  }
  
  .post-card {
    margin-bottom: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid #eeeeee;
  }

  .entry-header {
    margin-bottom: 1.5rem;
  }

  .entry-title {
    font-size: 26px;
    margin-bottom: 10px;
  }

  .entry-title a {
    color: var(--primary-color);
  }

  .entry-title a:hover {
    color: var(--accent-color);
  }

  .entry-meta {
    font-size: 13px;
    color: #999999;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .entry-meta a {
    color: #999999;
  }

  .entry-meta a:hover {
    color: var(--accent-color);
  }

  .entry-summary {
    color: #555555;
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .more-link-wrapper {
    margin-top: 20px;
  }

  .pagination {
    text-align: left;
    margin-top: 3rem;
  }
  @media (max-width: 992px) {
    .site-main {
      flex-direction: column;
      gap: 2rem;
    }
    
    .sidebar {
      width: 100%;
    }
  }
</style>
