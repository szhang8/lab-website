---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const recentPosts = posts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()).slice(0, 5);
---

<Layout title="Home">
  <div class="site-main">
    <div class="post-feed">
      {recentPosts.map(post => (
        <article class="post-card">
          <header class="entry-header">
            <h2 class="entry-title"><a href={`/blog/${post.slug}`}>{post.data.title}</a></h2>
            <div class="entry-meta">
              <span class="posted-on">
                <a href={`/blog/${post.slug}`}>
                  <time>{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                </a>
              </span>
              <span class="byline">Admin</span>
            </div>
          </header>
          
          <div class="entry-summary">
            {post.data.description ? (
              <p>{post.data.description}</p>
            ) : (
              <p>Keep reading to discover more about this topic...</p>
            )}
          </div>
          
          <div class="more-link-wrapper">
            <a href={`/blog/${post.slug}`} class="button more-link">Read more</a>
          </div>
        </article>
      ))}
    </div>
    
    <div class="pagination">
      <a href="/blog" class="button">Older posts</a>
    </div>
  </div>
</Layout>

<style>
  .site-main {
    max-width: 800px;
    margin: 4rem auto;
  }
  
  .post-card {
    margin-bottom: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid #eeeeee;
  }

  .entry-header {
    margin-bottom: 1.5rem;
  }

  .entry-title {
    font-size: 26px;
    margin-bottom: 10px;
  }

  .entry-title a {
    color: var(--primary-color);
  }

  .entry-title a:hover {
    color: var(--accent-color);
  }

  .entry-meta {
    font-size: 13px;
    color: #999999;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .entry-meta a {
    color: #999999;
  }

  .entry-meta a:hover {
    color: var(--accent-color);
  }

  .entry-summary {
    color: #555555;
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .more-link-wrapper {
    margin-top: 20px;
  }

  .pagination {
    text-align: left;
    margin-top: 3rem;
  }
</style>
