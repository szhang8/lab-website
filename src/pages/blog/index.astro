---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());
---

<Layout title="Lab News & Blog">
  <div class="site-main">
    <header class="page-header" style="margin-bottom: 4rem;">
      <h1 class="page-title" style="font-size: 26px;">Blog</h1>
    </header>

    <div class="post-feed">
      {sortedPosts.map(post => (
        <article class="post-card" style="margin-bottom: 4rem; padding-bottom: 4rem; border-bottom: 1px solid #eeeeee;">
          <header class="entry-header" style="margin-bottom: 1.5rem;">
            <h2 class="entry-title" style="font-size: 26px; margin-bottom: 10px;">
              <a href={`${base}blog/${post.slug}`} style="color: var(--primary-color);">{post.data.title}</a>
            </h2>
            <div class="entry-meta" style="font-size: 13px; color: #999999; text-transform: uppercase; letter-spacing: 1px;">
              <span class="posted-on">
                <time>{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              </span>
            </div>
          </header>
          
          <div class="entry-summary" style="color: #555555; font-size: 16px; line-height: 1.8;">
            {post.data.description ? (
              <p>{post.data.description}</p>
            ) : (
              <p>Keep reading to discover more about this topic...</p>
            )}
          </div>
          
          <div class="more-link-wrapper" style="margin-top: 20px;">
            <a href={`${base}blog/${post.slug}`} class="button">Read more</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>

<style>
  .site-main {
    max-width: 800px;
    margin: 4rem auto;
    padding: 0 20px;
  }
</style>
