---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import PageHeader from '../../components/PageHeader.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());
---

<Layout title="Lab Journal">
  <PageHeader title="Lab Journal" subtitle="Notes on discovery, metastasis, and cancer biology." />

  <section class="journal-index container">
    <div class="journal-grid">
      {sortedPosts.map(post => (
        <article class="journal-card reveal">
          <time class="post-date">{new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
          <h2 class="post-title"><a href={`${base}blog/${post.slug}/`}>{post.data.title}</a></h2>
          <p class="post-excerpt">{post.data.description || "Reflections from the bench and beyond..."}</p>
          <a href={`${base}blog/${post.slug}/`} class="read-link">Read entry</a>
        </article>
      ))}
    </div>
    
    {sortedPosts.length === 0 && (
      <p class="no-posts">No journal entries found. Please check your content directory.</p>
    )}
  </section>
</Layout>

<style>
  .journal-index {
    padding-bottom: 120px;
  }

  .journal-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 60px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .journal-card {
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 40px;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--accent-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
    display: block;
  }

  .post-title {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }

  .post-title a:hover { color: var(--accent-muted); }

  .post-excerpt {
    font-size: 1.05rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .read-link {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-main);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid var(--text-main);
    padding-bottom: 4px;
  }

  .read-link:hover {
    color: var(--accent-muted);
    border-color: var(--accent-muted);
  }

  .no-posts {
    text-align: center;
    color: var(--text-muted);
    margin-top: 4rem;
  }

  @media (max-width: 768px) {
    .journal-grid { grid-template-columns: 1fr; }
  }
</style>
