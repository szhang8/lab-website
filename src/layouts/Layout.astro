---
import '../styles/global.css';
import Header from '../components/Header.astro';
import { ClientRouter } from 'astro:transitions';
import { SEO } from "astro-seo";

interface Props {
  title: string;
  isHome?: boolean;
}

const { title, isHome = false } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const siteUrl = "https://www.curiosityrover.org";
const description = "The S.Zhang Laboratory at UT Southwestern Medical Center. Investigating tumor evolution, metastasis, and the microenvironment using single-cell genomics and high-definition imaging.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={`${base}uploads/2018/12/favicon.png`} />
    <meta name="generator" content={Astro.generator} />
    
    <SEO
      title={`${title} | S.Zhang Laboratory`}
      description={description}
      canonical={siteUrl}
      openGraph={{
        basic: {
          title: `${title} | S.Zhang Laboratory`,
          type: "website",
          image: `${siteUrl}/uploads/2018/12/Evolving-Minds-2.png`,
        },
        optional: {
          description: description,
          siteName: "S.Zhang Laboratory",
        }
      }}
      twitter={{
        creator: "@S_Zhang_Lab",
        card: "summary_large_image",
        site: "@S_Zhang_Lab",
        title: `${title} | S.Zhang Laboratory`,
        description: description,
        image: `${siteUrl}/uploads/2018/12/Evolving-Minds-2.png`,
      }}
    />

    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="078ed779-a401-45f0-83b2-a2b8d5fb21c5"></script>
    
    <ClientRouter />
  </head>
  <body>
    <Header isHome={isHome} />
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-content">
        <div class="footer-info">
          <span class="footer-logo serif-text">S.ZHANG <span class="light">LAB</span></span>
          <p>UT Southwestern Medical Center<br/>Dallas, Texas</p>
        </div>
        <div class="footer-copyright">
          <p>&copy; {new Date().getFullYear()} — Deciphering the Architecture of Life.</p>
        </div>
      </div>
    </footer>

    <script>
      // Global Reveal Animation Logic
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { 
        threshold: 0.05,
        rootMargin: '50px'
      });

      function observeReveals() {
        const elements = document.querySelectorAll('.reveal');
        elements.forEach(el => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight) {
            el.classList.add('active');
          } else {
            revealObserver.observe(el);
          }
        });
      }

      function initSocial() {
        if (document.querySelector('bsky-embed') && !document.querySelector('script[src*="bsky-embed"]')) {
          const script = document.createElement('script');
          script.type = 'module';
          script.src = 'https://cdn.jsdelivr.net/npm/bsky-embed/dist/bsky-embed.es.js';
          script.async = true;
          document.head.appendChild(script);
        }
      }

      observeReveals();
      initSocial();
      
      document.addEventListener('astro:page-load', () => {
        observeReveals();
        initSocial();
      });
    </script>
  </body>
</html>

<style is:global>
  main#content {
    min-height: 80vh;
  }
  
  :has(.hero) main#content {
    padding-top: 0;
  }

  main#content {
    padding-top: 100px;
  }

  .site-footer {
    padding: 80px 0;
    border-top: 1px solid var(--border-light);
    background-color: var(--bg-nordic);
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .footer-logo {
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text-main);
    display: block;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .footer-logo .light { font-weight: 300; opacity: 0.6; }

  @media (max-width: 768px) {
    .footer-content { flex-direction: column; align-items: flex-start; gap: 2rem; }
  }
</style>
