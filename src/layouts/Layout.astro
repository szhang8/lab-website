---
import '../styles/global.css';
import Header from './Header.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Exploring Cancer Biology @ UT Southwestern Medical Center" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/uploads/2018/12/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - Welcome to S.Zhang Laboratory</title>
  </head>
  <body>
    <div id="page" class="site">
      <Header />
      <div id="content" class="site-content">
        <slot />
      </div>
      <footer style="text-align: center; padding: 40px 20px; color: #555555; font-size: 14px; border-top: 1px solid #eeeeee;">
        <p>&copy; {new Date().getFullYear()} S.Zhang Laboratory. All rights reserved.</p>
      </footer>
    </div>
  </body>
</html>
