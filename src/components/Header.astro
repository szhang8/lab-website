---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<header class="site-header">
  <!-- Navigation on TOP -->
  <div class="top-nav">
    <div class="container nav-container">
      <button class="menu-toggle" aria-label="Toggle navigation">
        <span class="hamburger"></span>
      </button>
      <nav class="main-navigation">
        <ul id="primary-menu">
          <li><a href={`${base}research`}>Research</a></li>
          <li><a href={`${base}team`}>Team</a></li>
          <li><a href={`${base}publications`}>Publications</a></li>
          <li><a href={`${base}lab-arts`}>Biology is beautiful!</a></li>
          <li><a href={`${base}teaching`}>Mentoring</a></li>
          <li><a href={`${base}blog`}>Blog</a></li>
          <li><a href={`${base}contact-us`}>Contacts</a></li>
        </ul>
      </nav>
    </div>
  </div>

  <!-- Hero section with rotating backgrounds -->
  <div class="hero-section">
    <div class="slideshow"
         data-base={base}>
      <div class="slide active" data-bg={`${base}uploads/2018/12/cropped-Candy-dots.png`}></div>
      <div class="slide" data-bg={`${base}uploads/2018/12/cropped-Brain_astrocyte_microglia_10x-lens.jpg`}></div>
      <div class="slide" data-bg={`${base}uploads/2018/12/cropped-BBB.jpg`}></div>
      <div class="slide" data-bg={`${base}uploads/2018/12/cropped-Screen-Shot-2018-12-15-at-4.21.51-PM.png`}></div>
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <a href={base} rel="home" class="logo-link">
        <img src={`${base}uploads/2018/12/Evolving-Minds-2.png`} alt="Welcome to S.Zhang Laboratory" class="custom-logo" />
      </a>
      <h1 class="site-title">Welcome to S.Zhang Laboratory</h1>
      <p class="site-description">Exploring Cancer Biology @ UT Southwestern Medical Center</p>
    </div>
  </div>
</header>

<script>
  // Mobile Menu Toggle
  const menuToggle = document.querySelector('.menu-toggle');
  const mainNav = document.querySelector('.main-navigation');
  
  if (menuToggle && mainNav) {
    menuToggle.addEventListener('click', () => {
      menuToggle.classList.toggle('active');
      mainNav.classList.toggle('toggled');
    });
  }

  // Set background images from data attributes and rotate
  const slides = document.querySelectorAll('.slide');
  slides.forEach(slide => {
    const bg = slide.getAttribute('data-bg');
    if (bg) (slide as HTMLElement).style.backgroundImage = `url('${bg}')`;
  });

  let currentSlide = 0;
  function rotateSlides() {
    if (slides.length <= 1) return;
    slides[currentSlide].classList.remove('active');
    currentSlide = (currentSlide + 1) % slides.length;
    slides[currentSlide].classList.add('active');
  }
  
  setInterval(rotateSlides, 5000);
</script>

<style is:global>
  .site-header {
    position: relative;
  }

  /* Top navigation bar - red/maroon */
  .site-header .top-nav {
    background-color: #a33238 !important;
    padding: 0;
    position: relative;
    z-index: 100;
  }

  .nav-container {
    display: flex;
    justify-content: center;
    position: relative;
  }

  /* Mobile toggle button */
  .menu-toggle {
    display: none;
    background: none;
    border: none;
    padding: 15px;
    cursor: pointer;
    z-index: 101;
  }

  .hamburger {
    display: block;
    width: 20px;
    height: 2px;
    background: white;
    position: relative;
    transition: background 0.3s;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 2px;
    background: white;
    left: 0;
    transition: transform 0.3s;
  }

  .hamburger::before { top: -6px; }
  .hamburger::after { bottom: -6px; }

  .menu-toggle.active .hamburger { background: transparent; }
  .menu-toggle.active .hamburger::before { transform: translateY(6px) rotate(45deg); }
  .menu-toggle.active .hamburger::after { transform: translateY(-6px) rotate(-45deg); }

  .site-header .main-navigation ul {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 14px 0;
  }

  .site-header .main-navigation a {
    font-size: 13px;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #ffffff !important;
    display: block;
    white-space: nowrap;
  }

  .site-header .main-navigation a:hover {
    color: rgba(255, 255, 255, 0.75) !important;
  }

  /* Hero section */
  .site-header .hero-section {
    position: relative;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Slideshow backgrounds */
  .site-header .slideshow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .site-header .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }

  .site-header .slide.active {
    opacity: 1;
  }

  /* Dark overlay for readability */
  .site-header .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3);
    z-index: 1;
  }

  /* Hero content - all WHITE text */
  .site-header .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 60px 20px;
    width: 100%;
    max-width: 1200px;
  }

  .site-header .custom-logo {
    max-width: 90%;
    height: auto;
    width: auto;
    max-height: 280px;
    margin: 0 auto 2rem auto;
    display: block;
  }

  .site-header .site-title {
    font-size: 2.5rem;
    font-weight: 300;
    color: #ffffff !important;
    letter-spacing: 8px;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.5);
    line-height: 1.2;
    word-break: break-word;
  }

  .site-header .site-description {
    color: #ffffff !important;
    font-size: 16px;
    font-style: italic;
    margin-bottom: 0;
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.5);
    line-height: 1.4;
  }

  @media (max-width: 992px) {
    .menu-toggle {
      display: block;
    }

    .nav-container {
      justify-content: flex-end;
    }

    .site-header .main-navigation {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background-color: #a33238;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .site-header .main-navigation.toggled {
      display: block;
    }

    .site-header .main-navigation ul {
      flex-direction: column;
      gap: 0;
      padding: 0;
    }

    .site-header .main-navigation li {
      border-top: 1px solid rgba(255,255,255,0.1);
    }

    .site-header .main-navigation a {
      padding: 15px 20px;
      font-size: 14px;
    }
  }

  @media (max-width: 768px) {
    .site-header .hero-section {
      min-height: 400px;
    }

    .site-header .site-title {
      font-size: 1.8rem;
      letter-spacing: 3px;
    }

    .site-header .custom-logo {
      max-height: 180px;
      margin-bottom: 1.5rem;
    }
    
    .site-header .hero-content {
      padding: 40px 15px;
    }
  }

  @media (max-width: 480px) {
    .site-header .site-title {
      font-size: 1.4rem;
      letter-spacing: 1px;
    }
    
    .site-header .site-description {
      font-size: 14px;
    }

    .site-header .hero-section {
      min-height: 350px;
    }
  }
</style>

