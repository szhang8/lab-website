---
---

<header class="site-header">
  <!-- Navigation on TOP -->
  <div class="top-nav">
    <nav class="main-navigation">
      <ul>
        <li><a href="/research">Research</a></li>
        <li><a href="/team">Team</a></li>
        <li><a href="/publications">Publications</a></li>
        <li><a href="/lab-arts">Biology is beautiful!</a></li>
        <li><a href="/teaching">Mentoring</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact-us">Contacts</a></li>
      </ul>
    </nav>
  </div>

  <!-- Hero section with rotating backgrounds -->
  <div class="hero-section">
    <div class="slideshow">
      <div class="slide active" style="background-image: url('/uploads/2018/12/cropped-Candy-dots.png');"></div>
      <div class="slide" style="background-image: url('/uploads/2018/12/cropped-Brain_astrocyte_microglia_10x-lens.jpg');"></div>
      <div class="slide" style="background-image: url('/uploads/2018/12/cropped-BBB.jpg');"></div>
      <div class="slide" style="background-image: url('/uploads/2018/12/cropped-Screen-Shot-2018-12-15-at-4.21.51-PM.png');"></div>
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <a href="/" rel="home" class="logo-link">
        <img src="/uploads/2018/12/Evolving-Minds-2.png" alt="Welcome to S.Zhang Laboratory" class="custom-logo" />
      </a>
      <h1 class="site-title">Welcome to S.Zhang Laboratory</h1>
      <p class="site-description">Exploring Cancer Biology @ UT Southwestern Medical Center</p>
    </div>
  </div>
</header>

<script>
  // Simple slideshow rotation
  let currentSlide = 0;
  const slides = document.querySelectorAll('.slide');
  
  function rotateSlides() {
    slides[currentSlide].classList.remove('active');
    currentSlide = (currentSlide + 1) % slides.length;
    slides[currentSlide].classList.add('active');
  }
  
  setInterval(rotateSlides, 5000);
</script>

<style is:global>
  .site-header {
    position: relative;
  }

  /* Top navigation bar - red/maroon */
  .site-header .top-nav {
    background-color: #a33238 !important;
    padding: 14px 0;
    position: relative;
    z-index: 10;
  }

  .site-header .main-navigation ul {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .site-header .main-navigation a {
    font-size: 13px;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #ffffff !important;
  }

  .site-header .main-navigation a:hover {
    color: rgba(255, 255, 255, 0.75) !important;
  }

  /* Hero section */
  .site-header .hero-section {
    position: relative;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Slideshow backgrounds */
  .site-header .slideshow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .site-header .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }

  .site-header .slide.active {
    opacity: 1;
  }

  /* Dark overlay for readability */
  .site-header .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3);
    z-index: 1;
  }

  /* Hero content - all WHITE text */
  .site-header .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 60px 20px;
  }

  .site-header .custom-logo {
    max-width: 100%;
    height: auto;
    width: auto;
    max-height: 280px;
    margin: 0 auto 2rem auto;
    display: block;
  }

  .site-header .site-title {
    font-size: 2.5rem;
    font-weight: 300;
    color: #ffffff !important;
    letter-spacing: 8px;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.5);
  }

  .site-header .site-description {
    color: #ffffff !important;
    font-size: 16px;
    font-style: italic;
    margin-bottom: 0;
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.5);
  }

  @media (max-width: 768px) {
    .site-header .site-title {
      font-size: 22px;
      letter-spacing: 1px;
    }
    .site-header .main-navigation ul {
      gap: 0.75rem;
    }
    .site-header .main-navigation a {
      font-size: 11px;
    }
    .site-header .hero-section {
      min-height: 350px;
    }
  }
</style>
