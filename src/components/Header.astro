---
---

<header class="site-header">
  <div class="header-overlay">
    <div class="site-branding">
      <a href="/" rel="home" class="logo-link">
        <img src="/uploads/2018/12/Evolving-Minds-2.png" alt="Welcome to S.Zhang Laboratory" class="custom-logo" width="650" height="397" />
      </a>
      <h1 class="site-title"><a href="/">Welcome to S.Zhang Laboratory</a></h1>
      <p class="site-description">Exploring Cancer Biology @ UT Southwestern Medical Center</p>
    </div>

    <nav id="site-navigation" class="main-navigation container">
      <ul>
        <li><a href="/research">Research</a></li>
        <li><a href="/team">Team</a></li>
        <li><a href="/publications">Publications</a></li>
        <li><a href="/lab-arts">Biology is beautiful!</a></li>
        <li><a href="/teaching">Mentoring</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact-us">Contacts</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background-image: url('/uploads/2018/12/cropped-Candy-dots.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    border-bottom: 1px solid var(--border-color);
  }

  .header-overlay {
    background-color: rgba(255, 255, 255, 0.95);
    padding: 3rem 0;
  }

  .site-branding {
    text-align: center;
    margin-bottom: 2rem;
  }

  .custom-logo {
    max-width: 100%;
    height: auto;
    width: auto;
    max-height: 250px;
    margin: 0 auto 1.5rem auto;
    display: block;
  }

  .site-title {
    font-size: 32px;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .site-title a {
    color: #000000;
  }

  .site-description {
    color: #555555;
    font-size: 16px;
    margin-bottom: 0;
    font-style: italic;
  }

  .main-navigation {
    border-top: 1px solid #eeeeee;
    border-bottom: 1px solid #eeeeee;
    padding: 1rem 0;
    margin-top: 2rem;
  }

  .main-navigation ul {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    list-style: none;
    gap: 2rem;
  }

  .main-navigation a {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #333333;
  }

  .main-navigation a:hover {
    color: var(--accent-color);
  }

  @media (max-width: 768px) {
    .site-title {
      font-size: 24px;
    }
    .main-navigation ul {
      gap: 1rem;
      flex-direction: column;
      align-items: center;
    }
  }
</style>
